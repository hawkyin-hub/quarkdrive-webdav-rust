#!/bin/bash
# QuarkDrive-WebDAV launcher
# 1. Generate self-signed TLS cert if missing
# 2. Read quark cookie from /tmp/quark_cookie_backup
# 3. Start native TLS webdav server on port 8443

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RES_DIR="$SCRIPT_DIR/../Resources"
BIN="$SCRIPT_DIR/quarkdrive-webdav"

# Generate TLS cert if not present
CERT_DIR="$RES_DIR/certs"
bash "$RES_DIR/gen-cert.sh" "$CERT_DIR"
CERT="$CERT_DIR/localhost.pem"
KEY="$CERT_DIR/localhost-key.pem"

# Read cookie
COOKIE_FILE="/tmp/quark_cookie_backup"
if [[ ! -f "$COOKIE_FILE" ]]; then
    osascript -e 'display notification "请先登录夸克网盘获取 Cookie（保存到 /tmp/quark_cookie_backup）" with title "QuarkDrive WebDAV"'
    exit 1
fi

COOKIE="$(cat "$COOKIE_FILE")"

# Launch webdav server with TLS
exec "$BIN" \
    -U ujRx4Js1D \
    -W DVzv3ELQ3icn \
    -p 8443 \
    --tls-cert "$CERT" \
    --tls-key "$KEY" \
    --quark-cookie "$COOKIE" \
    --root /
